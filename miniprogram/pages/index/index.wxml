<!-- index.wxml -->
<view class="container">

  <!-- 背景 -->
  <view class="bg-layer"></view>

  <!-- 引导层 -->
  <view class="guide-layer {{introPhase >= 0 ? 'guide-visible' : ''}}" style="display: {{currentStep === -1 ? 'flex' : 'none'}}">
    <view class="guide-content">
      <text class="guide-title">I SEE YOU</text>
      <text class="guide-subtitle">我看见你了</text>
      <!-- 浮现文字 -->
      <view class="guide-appear-text" style="opacity: {{introPhase >= 0 ? 1 : 0}}; filter: blur({{introPhase >= 0 ? 0 : 12}}px); transform: translateY({{introPhase >= 0 ? 0 : 30}}px)">
        <text class="guide-question">此刻有什么人事物\n浮现在你的脑海里？</text>
      </view>
      <!-- 按钮 -->
      <view class="guide-btns" style="opacity: {{introPhase >= 1 ? 1 : 0}}">
        <button class="guide-btn" data-value="是" bindtap="onGuideChoice">是，有的</button>
        <button class="guide-btn guide-btn-secondary" data-value="否" bindtap="onGuideChoice">否，没有</button>
      </view>
    </view>
  </view>

  <!-- 主内容卡片 -->
  <view class="card {{showContent ? 'card-visible' : ''}" style="display: {{currentStep !== -1 ? 'flex' : 'none'}}">

    <!-- ══════════ Step 1: 物件 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 1}}">
      <view class="step-indicator"><text class="step-num">1</text></view>
      <text class="step-question">那个物件是什么？</text>
      <view class="btn-row">
        <button class="btn-primary" bindtap="onStep1Next">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 2: I SEE YOU ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 2}}">
      <view class="step-indicator"><text class="step-num">2</text></view>
      <text class="step-question">I SEE YOU</text>
      <view class="guide-btns">
        <button class="guide-btn" data-value="是" bindtap="onGuideChoice">是</button>
        <button class="guide-btn guide-btn-secondary" data-value="否" bindtap="onGuideChoice">否</button>
      </view>
    </view>

    <!-- ══════════ Step 3: 感受输入 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 3}}">
      <view class="step-indicator"><text class="step-num">3</text></view>
      <text class="step-question">此刻你感受到什么？</text>
      <textarea class="feeling-input" placeholder="用一句话描述你的感受…" value="{{feelingText}}" bindinput="onFeelingInput" maxlength="200"></textarea>
      <view class="btn-row">
        <button class="btn-primary" bindtap="onStep3Next">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 4: 允许存在？ ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 4}}">
      <view class="step-indicator"><text class="step-num">4</text></view>
      <text class="step-question">你允许这份感受存在吗？</text>
      <view class="btn-col">
        <button class="btn-primary" data-value="允许" bindtap="onAllowExist">允许</button>
        <button class="btn-secondary" data-value="不允许" bindtap="onAllowExist">不允许</button>
      </view>
    </view>

    <!-- ══════════ Step 5: 愿意放下？ ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 5}}">
      <view class="step-indicator"><text class="step-num">5</text></view>
      <text class="step-question">你愿意放下它吗？</text>
      <view class="btn-col">
        <button class="btn-primary" data-value="愿意" bindtap="onWantRelease">愿意</button>
        <button class="btn-secondary" data-value="不愿意" bindtap="onWantRelease">不愿意</button>
      </view>
    </view>

    <!-- ══════════ Step 6: 现在就放下？ ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 6}}">
      <view class="step-indicator"><text class="step-num">6</text></view>
      <text class="step-question">现在就把它放下，可以吗？</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onCanReleaseNow">可以的</button>
        <button class="btn-secondary" bindtap="onCanReleaseNow">有点难</button>
      </view>
    </view>

    <!-- ══════════ Step 7: 变淡还是清晰 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 7}}">
      <view class="step-indicator"><text class="step-num">7</text></view>
      <text class="step-question">此刻那份感受变淡了，还是更清晰了？</text>
      <view class="btn-col">
        <button class="btn-primary" data-value="变淡" bindtap="onFeelChange">变淡了</button>
        <button class="btn-secondary" data-value="清晰" bindtap="onFeelChange">更清晰了</button>
      </view>
    </view>

    <!-- ══════════ Step 8: 深呼吸3次 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 8}}">
      <view class="step-indicator"><text class="step-num">8</text></view>
      <text class="step-question">好，慢慢地做个深呼吸\n吸气……呼气……\n再一个\n吸气……呼气……</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onStep9Next">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 9: 读"我允许…" ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 9}}">
      <view class="step-indicator"><text class="step-num">9</text></view>
      <text class="step-question">请默念或轻声读出来：\n\n"我允许它的存在\n我看见它了\n我愿意让它待在这里\n此刻我选择放下它"</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onReadingDone">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 10: 结束 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 10}}">
      <view class="step-indicator"><text class="step-num">10</text></view>
      <text class="step-question">结束了。\n\n你可以随时回来，\n再次与自己连接。</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="restartPractice">再次开始</button>
        <button class="btn-secondary" bindtap="onBackToGuide">回到首页</button>
      </view>
      <view class="btn-col" style="margin-top: 40rpx;">
        <button class="btn-records" bindtap="toggleRecordsPanel">
          {{showRecordsPanel ? '收起记录' : '查看释放记录'}}
        </button>
      </view>
    </view>

    <!-- ══════════ Step 12: 三选一 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 11}}">
      <view class="step-indicator"><text class="step-num">12</text></view>
      <text class="step-question">你最想要的是？</text>
      <view class="desire-grid">
        <button class="desire-btn" data-value="被认可" bindtap="onChooseDesire">被认可</button>
        <button class="desire-btn" data-value="想要控制" bindtap="onChooseDesire">想要控制</button>
        <button class="desire-btn" data-value="想要安全" bindtap="onChooseDesire">想要安全</button>
      </view>
    </view>

    <!-- ══════════ Step 13: 能否允许想要被认可 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 12}}">
      <view class="step-indicator"><text class="step-num">13</text></view>
      <text class="step-question">你能否允许自己有这个想要？</text>
      <view class="btn-col">
        <button class="btn-primary" data-value="能" bindtap="onAllowDesire">能</button>
        <button class="btn-secondary" data-value="不能" bindtap="onAllowDesire">不能</button>
      </view>
    </view>

    <!-- ══════════ Step 14/15/16: 说三遍 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 13 || currentStep === 14 || currentStep === 15}}">
      <view class="step-indicator"><text class="step-num">{{currentStep === 13 ? 14 : currentStep === 14 ? 15 : 16}}</text></view>
      <text class="step-question">请默念或轻声读出来：\n\n"我允许自己想要被认可\n我看见我自己在渴望被认可\n我愿意陪伴这份渴望\n此刻我选择放下控制"</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onSpeechDone">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 17: 感受想要 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 16}}">
      <view class="step-indicator"><text class="step-num">17</text></view>
      <text class="step-question">此刻再感受一下那份"想要被认可"，\n它的感受是什么？</text>
      <textarea class="feeling-input" placeholder="用一句话描述…" value="{{desireText}}" bindinput="onDesireInput" maxlength="200"></textarea>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onFeelDone">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 18: 能否允许想要控制 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 17}}">
      <view class="step-indicator"><text class="step-num">18</text></view>
      <text class="step-question">你能否允许自己有这个想要？</text>
      <view class="btn-col">
        <button class="btn-primary" data-value="能" bindtap="onAllowDesire">能</button>
        <button class="btn-secondary" data-value="不能" bindtap="onAllowDesire">不能</button>
      </view>
    </view>

    <!-- ══════════ Step 19/20/21: 说三遍 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 18 || currentStep === 19 || currentStep === 20}}">
      <view class="step-indicator"><text class="step-num">{{currentStep === 18 ? 19 : currentStep === 19 ? 20 : 21}}</text></view>
      <text class="step-question">请默念或轻声读出来：\n\n"我允许自己想要控制\n我看见我自己在渴望控制\n我愿意陪伴这份渴望\n此刻我选择放下控制"</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onSpeechDone">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 22: 能否允许想要安全 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 21}}">
      <view class="step-indicator"><text class="step-num">22</text></view>
      <text class="step-question">你能否允许自己有这个想要？</text>
      <view class="btn-col">
        <button class="btn-primary" data-value="能" bindtap="onAllowDesire">能</button>
        <button class="btn-secondary" data-value="不能" bindtap="onAllowDesire">不能</button>
      </view>
    </view>

    <!-- ══════════ Step 23/24/25: 说三遍 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 22 || currentStep === 23 || currentStep === 24}}">
      <view class="step-indicator"><text class="step-num">{{currentStep === 22 ? 23 : currentStep === 23 ? 24 : 25}}</text></view>
      <text class="step-question">请默念或轻声读出来：\n\n"我允许自己想要安全\n我看见我自己在渴望安全\n我愿意陪伴这份渴望\n此刻我选择放下控制"</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onSpeechDone">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 26: 不愿意底下想要什么 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 25}}">
      <view class="step-indicator"><text class="step-num">26</text></view>
      <text class="step-question">在"不愿意"底下，你想要什么？</text>
      <textarea class="feeling-input" placeholder="用一句话描述…" value="{{desireText}}" bindinput="onDesireInput" maxlength="200"></textarea>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onDesireConfirm">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 27: 能否允许 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 26}}">
      <view class="step-indicator"><text class="step-num">27</text></view>
      <text class="step-question">你能否允许自己有这个想要？</text>
      <view class="btn-col">
        <button class="btn-primary" data-value="能" bindtap="onAllowThese">能</button>
        <button class="btn-secondary" data-value="不能" bindtap="onAllowThese">不能</button>
      </view>
    </view>

    <!-- ══════════ Step 28/29/30: 说三遍 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 27 || currentStep === 28 || currentStep === 29}}">
      <view class="step-indicator"><text class="step-num">{{currentStep === 27 ? 28 : currentStep === 28 ? 29 : 30}}</text></view>
      <text class="step-question">请默念或轻声读出来：\n\n"我允许它的存在\n我看见它了\n我愿意让它待在这里\n此刻我选择放下它"</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onSpeechDone">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 31: 不允许抗拒 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 30}}">
      <view class="step-indicator"><text class="step-num">31</text></view>
      <text class="step-question">你能否允许自己对它的抗拒存在？</text>
      <view class="btn-col">
        <button class="btn-primary" data-value="允许" bindtap="onAllowResistance">允许</button>
        <button class="btn-secondary" data-value="不允许" bindtap="onAllowResistance">不允许</button>
      </view>
    </view>

    <!-- ══════════ Step 32: 不能允许 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 31}}">
      <view class="step-indicator"><text class="step-num">32</text></view>
      <text class="step-question">你能否允许自己不能允许？</text>
      <view class="btn-col">
        <button class="btn-primary" data-value="能" bindtap="onCanNotRelease">能</button>
        <button class="btn-secondary" data-value="不能" bindtap="onCanNotRelease">不能</button>
      </view>
    </view>

    <!-- ══════════ Step 33: 深呼吸说出来 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 32}}">
      <view class="step-indicator"><text class="step-num">33</text></view>
      <text class="step-question">好，慢慢做个深呼吸\n把"我不能允许"说出来\n感受它穿过你的身体</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onBreatheDone">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 34: 身体紧绷 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 33}}">
      <view class="step-indicator"><text class="step-num">34</text></view>
      <text class="step-question">去感受身体里那份紧绷\n感受它所在的位置\n温柔地陪伴它</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onTensionNext">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 35: 愿不愿意和紧绷待在一起 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 34}}">
      <view class="step-indicator"><text class="step-num">35</text></view>
      <text class="step-question">你愿不愿意和这份紧绷\n待在一起？</text>
      <view class="btn-col">
        <button class="btn-primary" data-value="愿意" bindtap="onStayWithTension">愿意</button>
        <button class="btn-secondary" data-value="不愿意" bindtap="onStayWithTension">不愿意</button>
      </view>
    </view>

    <!-- ══════════ Step 36: 再来一次 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 35}}">
      <view class="step-indicator"><text class="step-num">36</text></view>
      <text class="step-question">好，慢慢做个深呼吸\n感受紧绷经过你的身体\n允许它来，也允许它离开</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onTensionAgain">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 37: 最后一次 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 36}}">
      <view class="step-indicator"><text class="step-num">37</text></view>
      <text class="step-question">再来一次\n吸气……呼气……\n感受它慢慢消散</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onTensionFinal">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 38: 一起待着 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 37}}">
      <view class="step-indicator"><text class="step-num">38</text></view>
      <text class="step-question">你也可以选择\n就这样和它待一会儿\n不急着放下</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onStayTogether">继续</button>
      </view>
    </view>

    <!-- ══════════ Step 39: 读允许 ══════════ -->
    <view class="step-content" wx:if="{{currentStep === 38}}">
      <view class="step-indicator"><text class="step-num">39</text></view>
      <text class="step-question">请默念或轻声读出来：\n\n"我允许它的存在\n我看见它了\n我愿意让它待在这里\n此刻我选择放下它"</text>
      <view class="btn-col">
        <button class="btn-primary" bindtap="onFinalReadingDone">继续</button>
      </view>
    </view>

    <!-- ══════════ 释放记录面板 ══════════ -->
    <view class="records-panel {{showRecordsPanel ? 'records-visible' : ''}}" wx:if="{{showRecordsPanel}}">
      <view class="records-header">
        <text class="records-title">释放记录</text>
        <text class="records-count">{{releaseRecords.length}} 条</text>
      </view>
      <scroll-view class="records-list" scroll-y>
        <view wx:for="{{releaseRecords}}" wx:key="timestamp" class="record-item">
          <view class="record-content" data-record="{{item}}" bindtap="loadRecord">
            <text class="record-date">{{formatDate(item.timestamp)}}</text>
            <text class="record-feeling">{{item.feeling}}</text>
            <text class="record-desire" wx:if="{{item.desire}}">{{item.desire}} · {{item.desireText}}</text>
          </view>
          <view class="record-delete" data-index="{{index}}" bindtap="deleteRecord">×</view>
        </view>
        <view class="records-empty" wx:if="{{releaseRecords.length === 0}}">
          <text>暂无记录</text>
        </view>
      </scroll-view>
    </view>

  </view>

  <!-- BGM 按钮 -->
  <view class="bgm-btn" bindtap="onBgmToggle">
    <text class="bgm-icon">{{bgmEnabled ? '🔊' : '🔇'}}</text>
  </view>

</view>
